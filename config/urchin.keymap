/*
 * Urchin 34-key ZMK keymap (revised)
 * ============================================================
 *
 * Base layout : Colemak-DH
 * Host OS     : Windows
 * Host layout : US-International
 * Language    : Portuguese (Brazil)
 *
 * Layers
 * ------
 * 0  BASE       Colemak-DH alphas
 * 1  MERGED     Nav + Numpad + Symbols (hold left outer thumb)
 * 2  ACC_ACUTE  Agudo / Til          (tap left outer thumb)
 * 3  ACC_GRAVE  Crase / Circunflexo  (double-tap position 29)
 * 4  BT         Bluetooth settings   (both left thumbs combo)
 *
 * Thumb cluster
 * -------------
 * Left outer  : tap → sticky Accent Acute | hold → momentary Merged
 * Left inner  : tap → Space               | hold → Ctrl
 * Right inner : tap → Enter               | hold → Shift
 * Right outer : Backspace (plain, repeatable)
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

#define BASE      0
#define MERGED    1
#define ACC_ACUTE 2
#define ACC_GRAVE 3
#define BT        4

/ {

    behaviors {

        /* ---- Thumb behaviours ---- */

        /* Left outer thumb: hold → mo MERGED, tap → sl ACC_ACUTE */
        thumb_layer_accent: thumb_layer_accent {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <220>;
            quick-tap-ms = <180>;
            bindings = <&mo>, <&sl>;
        };

        /* Generic kp hold-tap (thumbs, symbols, brackets) */
        sym_ht: sym_ht {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <220>;
            quick-tap-ms = <180>;
            bindings = <&kp>, <&kp>;
        };

        /* Position 29 tap-dance: 1 tap → Tab/Win hold-tap, 2 taps → sl ACC_GRAVE */
        td_tab_acc_grave: td_tab_acc_grave {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <220>;
            bindings = <&sym_ht LGUI TAB>, <&sl ACC_GRAVE>;
        };

        /* ---- Alpha hold-tap (260 ms) ---- */

        alpha_up: alpha_up {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <260>;
            quick-tap-ms = <180>;
            bindings = <&kp>, <&kp>;
        };

        /* ---- Accent-layer hold-taps (260 ms) ---- */

        /* ACC_ACUTE  A : tap á  | hold ã */
        ht_a_agudo: ht_a_agudo {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <260>;
            quick-tap-ms = <180>;
            bindings = <&out_atilde>, <&out_aacute>;
        };

        /* ACC_ACUTE  R : tap Á  | hold Ã */
        ht_A_agudo: ht_A_agudo {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <260>;
            quick-tap-ms = <180>;
            bindings = <&out_atilde_uc>, <&out_aacute_uc>;
        };

        /* ACC_ACUTE  O : tap ó  | hold õ */
        ht_o_agudo: ht_o_agudo {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <260>;
            quick-tap-ms = <180>;
            bindings = <&out_otilde>, <&out_oacute>;
        };

        /* ACC_ACUTE  ? : tap Ó  | hold Õ */
        ht_O_agudo: ht_O_agudo {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <260>;
            quick-tap-ms = <180>;
            bindings = <&out_otilde_uc>, <&out_oacute_uc>;
        };

        /* ACC_GRAVE  A : tap à  | hold â */
        ht_a_crase: ht_a_crase {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <260>;
            quick-tap-ms = <180>;
            bindings = <&out_acirc>, <&out_agrave>;
        };

        /* ACC_GRAVE  R : tap À  | hold Â */
        ht_A_crase: ht_A_crase {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <260>;
            quick-tap-ms = <180>;
            bindings = <&out_acirc_uc>, <&out_agrave_uc>;
        };

        /* Both accent layers  C : tap ç  | hold Ç */
        ht_c_cedil: ht_c_cedil {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <260>;
            quick-tap-ms = <180>;
            bindings = <&out_ccedil_uc>, <&out_ccedil>;
        };
    };

    /* ============================================================
     *  MACROS
     * ============================================================ */
    macros {

        /* ---- Utility ---- */

        screenshot_tool: screenshot_tool {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <20>;
            tap-ms = <20>;
            bindings
                = <&macro_press &kp LGUI>
                , <&macro_press &kp LSHIFT>
                , <&macro_tap &kp S>
                , <&macro_release &kp LSHIFT>
                , <&macro_release &kp LGUI>
                ;
        };

        lock_screen: lock_screen {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <20>;
            tap-ms = <20>;
            bindings
                = <&macro_press &kp LGUI>
                , <&macro_tap &kp L>
                , <&macro_release &kp LGUI>
                ;
        };

        alt_tab: alt_tab {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <20>;
            tap-ms = <20>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp TAB>
                , <&macro_release &kp LALT>
                ;
        };

        alt_shift_tab: alt_shift_tab {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <20>;
            tap-ms = <20>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_press &kp LSHIFT>
                , <&macro_tap &kp TAB>
                , <&macro_release &kp LSHIFT>
                , <&macro_release &kp LALT>
                ;
        };

        /* ---- Alt-code accents ---- */

        /* à  Alt+0224 */
        out_agrave: out_agrave {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N2 &kp KP_N4>
                , <&macro_release &kp LALT>
                ;
        };

        /* À  Alt+0192 */
        out_agrave_uc: out_agrave_uc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N1 &kp KP_N9 &kp KP_N2>
                , <&macro_release &kp LALT>
                ;
        };

        /* á  Alt+0225 */
        out_aacute: out_aacute {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N2 &kp KP_N5>
                , <&macro_release &kp LALT>
                ;
        };

        /* Á  Alt+0193 */
        out_aacute_uc: out_aacute_uc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N1 &kp KP_N9 &kp KP_N3>
                , <&macro_release &kp LALT>
                ;
        };

        /* â  Alt+0226 */
        out_acirc: out_acirc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N2 &kp KP_N6>
                , <&macro_release &kp LALT>
                ;
        };

        /* Â  Alt+0194 */
        out_acirc_uc: out_acirc_uc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N1 &kp KP_N9 &kp KP_N4>
                , <&macro_release &kp LALT>
                ;
        };

        /* ã  Alt+0227 */
        out_atilde: out_atilde {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N2 &kp KP_N7>
                , <&macro_release &kp LALT>
                ;
        };

        /* Ã  Alt+0195 */
        out_atilde_uc: out_atilde_uc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N1 &kp KP_N9 &kp KP_N5>
                , <&macro_release &kp LALT>
                ;
        };

        /* ç  Alt+0231 */
        out_ccedil: out_ccedil {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N3 &kp KP_N1>
                , <&macro_release &kp LALT>
                ;
        };

        /* Ç  Alt+0199 */
        out_ccedil_uc: out_ccedil_uc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N1 &kp KP_N9 &kp KP_N9>
                , <&macro_release &kp LALT>
                ;
        };

        /* é  Alt+0233 */
        out_eacute: out_eacute {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N3 &kp KP_N3>
                , <&macro_release &kp LALT>
                ;
        };

        /* É  Alt+0201 */
        out_eacute_uc: out_eacute_uc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N0 &kp KP_N1>
                , <&macro_release &kp LALT>
                ;
        };

        /* ê  Alt+0234 */
        out_ecirc: out_ecirc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N3 &kp KP_N4>
                , <&macro_release &kp LALT>
                ;
        };

        /* í  Alt+0237 */
        out_iacute: out_iacute {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N3 &kp KP_N7>
                , <&macro_release &kp LALT>
                ;
        };

        /* Í  Alt+0205 */
        out_iacute_uc: out_iacute_uc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N0 &kp KP_N5>
                , <&macro_release &kp LALT>
                ;
        };

        /* ó  Alt+0243 */
        out_oacute: out_oacute {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N4 &kp KP_N3>
                , <&macro_release &kp LALT>
                ;
        };

        /* Ó  Alt+0211 */
        out_oacute_uc: out_oacute_uc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N1 &kp KP_N1>
                , <&macro_release &kp LALT>
                ;
        };

        /* õ  Alt+0245 */
        out_otilde: out_otilde {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N4 &kp KP_N5>
                , <&macro_release &kp LALT>
                ;
        };

        /* Õ  Alt+0213 */
        out_otilde_uc: out_otilde_uc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N1 &kp KP_N3>
                , <&macro_release &kp LALT>
                ;
        };

        /* ô  Alt+0244 */
        out_ocirc: out_ocirc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N4 &kp KP_N4>
                , <&macro_release &kp LALT>
                ;
        };

        /* ú  Alt+0250 */
        out_uacute: out_uacute {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N5 &kp KP_N0>
                , <&macro_release &kp LALT>
                ;
        };

        /* Ú  Alt+0218 */
        out_uacute_uc: out_uacute_uc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <25>;
            tap-ms = <25>;
            bindings
                = <&macro_press &kp LALT>
                , <&macro_tap &kp KP_N0 &kp KP_N2 &kp KP_N1 &kp KP_N8>
                , <&macro_release &kp LALT>
                ;
        };
    };

    /* ============================================================
     *  COMBOS
     * ============================================================ */
    combos {
        compatible = "zmk,combos";

        /* Colon — comma (27) + ? (28) */
        combo_colon {
            timeout-ms = <40>;
            require-prior-idle-ms = <100>;
            key-positions = <27 28>;
            bindings = <&kp LS(SEMI)>;
            layers = <BASE>;
        };

        /* Caps Word — Z (20) + R (11) */
        combo_caps_word {
            timeout-ms = <40>;
            require-prior-idle-ms = <100>;
            key-positions = <20 11>;
            bindings = <&caps_word>;
            layers = <BASE>;
        };

        /* Mute — Tab/Win (29) + J (5) */
        combo_mute {
            timeout-ms = <50>;
            require-prior-idle-ms = <80>;
            key-positions = <29 5>;
            bindings = <&kp C_MUTE>;
            layers = <BASE>;
        };

        /* Volume down — Tab/Win (29) + L (6) */
        combo_vol_dn {
            timeout-ms = <50>;
            require-prior-idle-ms = <80>;
            key-positions = <29 6>;
            bindings = <&kp C_VOL_DN>;
            layers = <BASE>;
        };

        /* Volume up — Tab/Win (29) + U (7) */
        combo_vol_up {
            timeout-ms = <50>;
            require-prior-idle-ms = <80>;
            key-positions = <29 7>;
            bindings = <&kp C_VOL_UP>;
            layers = <BASE>;
        };

        /* Lock screen — Tab/Win (29) + Y (8) */
        combo_lock {
            timeout-ms = <50>;
            require-prior-idle-ms = <80>;
            key-positions = <29 8>;
            bindings = <&lock_screen>;
            layers = <BASE>;
        };

        /* Screenshot — Tab/Win (29) + ' (9) */
        combo_screenshot {
            timeout-ms = <50>;
            require-prior-idle-ms = <80>;
            key-positions = <29 9>;
            bindings = <&screenshot_tool>;
            layers = <BASE>;
        };

        /* App left — Tab/Win (29) + M (15) */
        combo_app_left {
            timeout-ms = <50>;
            require-prior-idle-ms = <80>;
            key-positions = <29 15>;
            bindings = <&alt_shift_tab>;
            layers = <BASE>;
        };

        /* App right — Tab/Win (29) + N (16) */
        combo_app_right {
            timeout-ms = <50>;
            require-prior-idle-ms = <80>;
            key-positions = <29 16>;
            bindings = <&alt_tab>;
            layers = <BASE>;
        };

        /* BT layer — both left thumbs (30 + 31) */
        combo_bt_momentary {
            timeout-ms = <50>;
            require-prior-idle-ms = <80>;
            key-positions = <30 31>;
            bindings = <&mo BT>;
        };
    };

    /* ============================================================
     *  KEYMAP
     * ============================================================ */
    keymap {
        compatible = "zmk,keymap";

        /* --------------------------------------------------------
         *  BASE — Colemak-DH
         * --------------------------------------------------------
         *  Q  W  F  P  B  |  J  L  U  Y  '
         *  A  R  S  T  G  |  M  N  E  I  O
         *  Z  X  C  D  V  |  K  H  ,. ?! Tab/Win
         *    [ACC_ACU/MERGED] [SPC/Ctrl] | [ENT/Shft] [BSPC]
         * ------------------------------------------------------ */
        base_layer {
            display-name = "Base";
            bindings = <
                &alpha_up LS(Q) Q    &alpha_up LS(W) W    &alpha_up LS(F) F    &alpha_up LS(P) P    &alpha_up LS(B) B       &alpha_up LS(J) J    &alpha_up LS(L) L    &alpha_up LS(U) U    &alpha_up LS(Y) Y    &kp SQT
                &alpha_up LS(A) A    &alpha_up LS(R) R    &alpha_up LS(S) S    &alpha_up LS(T) T    &alpha_up LS(G) G       &alpha_up LS(M) M    &alpha_up LS(N) N    &alpha_up LS(E) E    &alpha_up LS(I) I    &alpha_up LS(O) O
                &alpha_up LS(Z) Z    &alpha_up LS(X) X    &alpha_up LS(C) C    &alpha_up LS(D) D    &alpha_up LS(V) V       &alpha_up LS(K) K    &alpha_up LS(H) H    &sym_ht DOT COMMA    &sym_ht LS(N1) LS(FSLH)  &td_tab_acc_grave
                &thumb_layer_accent MERGED ACC_ACUTE      &sym_ht LCTRL SPACE                                                &sym_ht LSHIFT ENTER &kp BSPC
            >;
        };

        /* --------------------------------------------------------
         *  MERGED — Nav + Numpad + Symbols
         * --------------------------------------------------------
         *  Esc  PgUp PgDn  %    "   |  *   7   8   9   +
         *  </>  {/}   ↑   [/]  (/) |  /   4   5   6   -
         *  Ctrl  ←    ↓    →   =/@  |  _   1   2   3   0
         *         [trans]  [trans]   | [trans] [trans]
         * ------------------------------------------------------ */
        merged_layer {
            display-name = "Merged";
            bindings = <
                &kp ESC                      &kp PG_UP                    &kp PG_DN                    &kp LS(N5)                   &kp LS(SQT)                    &kp LS(N8)       &kp N7           &kp N8           &kp N9           &kp LS(EQUAL)
                &sym_ht LS(DOT) LS(COMMA)    &sym_ht LS(RBKT) LS(LBKT)   &kp UP                       &sym_ht RBKT LBKT            &sym_ht LS(N0) LS(N9)          &kp FSLH         &kp N4           &kp N5           &kp N6           &kp MINUS
                &kp LCTRL                    &kp LEFT                     &kp DOWN                     &kp RIGHT                    &sym_ht LS(N2) EQUAL           &kp LS(MINUS)    &kp N1           &kp N2           &kp N3           &kp N0
                &trans                       &trans                                                                                                                 &trans           &trans
            >;
        };

        /* --------------------------------------------------------
         *  ACC_ACUTE — Agudo (tap) / Til (hold)
         * --------------------------------------------------------
         *  .   .   .   .   .  |  .   .   ú   Ú   .
         *  á/ã Á/Ã .   .   .  |  .   .   é   í  ó/õ
         *  .   .   ç/Ç .   .  |  .   .   É   Í  Ó/Õ
         *       [trans] [trans] | [trans] [trans]
         * ------------------------------------------------------ */
        accent_acute_layer {
            display-name = "Agudo";
            bindings = <
                &none                &none                &none                &none                &none                   &none                &none                &out_uacute          &out_uacute_uc       &none
                &ht_a_agudo 0 0      &ht_A_agudo 0 0      &none                &none                &none                   &none                &none                &out_eacute          &out_iacute          &ht_o_agudo 0 0
                &none                &none                &ht_c_cedil 0 0      &none                &none                   &none                &none                &out_eacute_uc       &out_iacute_uc       &ht_O_agudo 0 0
                &trans               &trans                                                                                  &trans               &trans
            >;
        };

        /* --------------------------------------------------------
         *  ACC_GRAVE — Crase (tap) / Circunflexo (hold)
         * --------------------------------------------------------
         *  .    .   .   .   .  |  .   .   .   .   .
         *  à/â À/Â .   .   .  |  .   .   ê   .   ô
         *  .    .  ç/Ç .   .  |  .   .   .   .   .
         *       [trans] [trans] | [trans] [trans]
         * ------------------------------------------------------ */
        accent_grave_layer {
            display-name = "Crase";
            bindings = <
                &none                &none                &none                &none                &none                   &none                &none                &none                &none                &none
                &ht_a_crase 0 0      &ht_A_crase 0 0      &none                &none                &none                   &none                &none                &out_ecirc           &none                &out_ocirc
                &none                &none                &ht_c_cedil 0 0      &none                &none                   &none                &none                &none                &none                &none
                &trans               &trans                                                                                  &trans               &trans
            >;
        };

        /* --------------------------------------------------------
         *  BT — Bluetooth settings
         * -------------------------------------------------------- */
        bluetooth_layer {
            display-name = "BT";
            bindings = <
                &none                &bt BT_CLR           &bootloader          &none                &none                   &bt BT_SEL 0         &bt BT_SEL 1         &bt BT_SEL 2         &bt BT_SEL 3         &none
                &none                &none                &none                &none                &none                   &bt BT_SEL 4         &bt BT_SEL 5         &none                &none                &none
                &none                &none                &none                &none                &none                   &none                &none                &none                &none                &none
                &trans               &trans                                                                                  &trans               &trans
            >;
        };
    };
};
